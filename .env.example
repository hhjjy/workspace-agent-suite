# ============================================================
# .env.example — 複製成 .env 後填入你自己的值
#   cp .env.example .env   (或在 Windows: copy .env.example .env)
# 切勿把填好的 .env 上傳到 git!(.env 已在 .gitignore)
# ============================================================

# === LLM Settings ===
# Provider: openrouter (預設) | openai
# 要換成 GPT-4o:provider 改 openai、填 OPENAI_API_KEY、model 改 gpt-4o
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_BASE_URL=https://openrouter.ai/api/v1

# === API Keys ===
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-...           # 切換到 GPT-4o 時才需要

# === Google OAuth 2.0 (Desktop App) ===
# 從 Google Cloud Console 建立 OAuth 憑證後取得;見 README「Setup」
# USER_GOOGLE_EMAIL = agent 要操作的那個 Google 帳號(行事曆 + 收信信箱)
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
USER_GOOGLE_EMAIL=your-agent-account@gmail.com

# === Dev Settings ===
# 只用於本機開發,允許 OAuth 走 HTTP(正式環境請勿開啟)
OAUTHLIB_INSECURE_TRANSPORT=1

# 注:測試資料注入(testdata/)走的是同一套 MCP OAuth —— 跑過 auth_setup.py
# 就能用,不需要額外的 SMTP 帳號或 Gmail 應用程式密碼。
