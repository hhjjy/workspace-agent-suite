# ============================================================
# .env.example — 複製成 .env 後填入你自己的值
#   cp .env.example .env   (或在 Windows: copy .env.example .env)
# 切勿把填好的 .env 上傳到 git!(.env 已在 .gitignore)
# ============================================================

# === LLM Settings ===
# Provider: openrouter (預設) | openai
# 要換成 GPT-4o:provider 改 openai、填 OPENAI_API_KEY、model 改 gpt-4o
# 💡 Demo 想最穩:用 GPT-4o。deepseek-v4-flash 較省但多步工具鏈/工具後總結偶爾會漏,
#    現場若出現「無文字回覆」或沒接續工具,改用 GPT-4o 可大幅降低機率。
LLM_PROVIDER=openrouter
LLM_MODEL=deepseek/deepseek-v4-flash
LLM_BASE_URL=https://openrouter.ai/api/v1

# === API Keys ===
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-...           # 切換到 GPT-4o 時才需要

# === Google OAuth 2.0 (Desktop App) ===
# 從 Google Cloud Console 建立 OAuth 憑證後取得;見 README「Setup」
# USER_GOOGLE_EMAIL = agent 要操作的那個 Google 帳號(行事曆 + 收信信箱)
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
USER_GOOGLE_EMAIL=your-agent-account@gmail.com

# === Dev Settings ===
# 只用於本機開發,允許 OAuth 走 HTTP(正式環境請勿開啟)
OAUTHLIB_INSECURE_TRANSPORT=1

# === SMTP Settings (for testdata/send_test_emails_smtp.py) ===
# 對齊規範版作法:從「另一個」Gmail 帳號透過 SMTP 寄 8 封測試信給 agent 信箱。
# 預設的 send_test_emails.py 是走 MCP/OAuth 自寄自,不需要這三個變數;
# 只有要用 SMTP + 兩個不同帳號的場景才需要填。
#
# 取得 App Password 步驟:
#   1. 寄件帳號開啟兩階段驗證 (myaccount.google.com/security)
#   2. 至 myaccount.google.com/apppasswords 產生 16 碼密碼
#   3. 將 16 碼(去空格)貼入 SMTP_APP_PASSWORD
# 限制:App Password 只能用於個人 Gmail,不支援 Workspace (公司/學校) 帳號。
#
# SMTP_TARGET_EMAIL 通常設為與 USER_GOOGLE_EMAIL 相同(agent 監控的信箱);
# 若留空,程式會自動 fallback 為 USER_GOOGLE_EMAIL。
SMTP_SENDER_EMAIL=your-sender-account@gmail.com
SMTP_APP_PASSWORD=xxxxxxxxxxxxxxxx
SMTP_TARGET_EMAIL=your-agent-account@gmail.com

# 注:預設的 testdata/send_test_emails.py 走的是同一套 MCP OAuth —— 跑過 auth_setup.py
# 就能用,不需要額外的 SMTP 帳號或 Gmail 應用程式密碼。
# 只有 testdata/send_test_emails_smtp.py 才需要 SMTP_* 三個變數。
